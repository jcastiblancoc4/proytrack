<div class="max-w-5xl mx-auto px-4 mt-6" x-data="{ open: <%= @third_party&.errors&.any? ? 'true' : 'false' %> }">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Terceros</h1>
    <button @click="open = true"
            class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-4 py-2 rounded">
      Nuevo Tercero
    </button>
  </div>

  <!-- Modal -->
  <div x-show="open"
       x-transition:enter="transition ease-out duration-200"
       x-transition:enter-start="opacity-0"
       x-transition:enter-end="opacity-100"
       x-transition:leave="transition ease-in duration-150"
       x-transition:leave-start="opacity-100"
       x-transition:leave-end="opacity-0"
       class="fixed inset-0 z-50 flex items-center justify-center bg-black/50"
       style="display: none;">
    <div @click.outside="open = false"
         class="bg-white rounded-xl shadow-xl w-full max-w-lg mx-4 p-6 max-h-[90vh] overflow-y-auto">
      <div class="flex justify-between items-center mb-5">
        <h2 class="text-lg font-bold text-gray-900">Nuevo Tercero</h2>
        <button @click="open = false" class="text-gray-400 hover:text-gray-600">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <%= render "form", third_party: @third_party || ThirdParty.new %>
    </div>
  </div>

  <% if @third_parties.any? %>
    <div class="bg-white rounded-xl shadow border border-gray-100 overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 text-gray-600 uppercase text-xs">
          <tr>
            <th class="px-4 py-3 text-left">Nombre / Razón Social</th>
            <th class="px-4 py-3 text-left">Tipo</th>
            <th class="px-4 py-3 text-left">Documento</th>
            <th class="px-4 py-3 text-left">Contacto</th>
            <th class="px-4 py-3 text-center">Acciones</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @third_parties.each do |tp| %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3 font-medium text-gray-800"><%= tp.full_name %></td>
              <td class="px-4 py-3">
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                  <%= tp.person? ? 'bg-blue-100 text-blue-800' : 'bg-purple-100 text-purple-800' %>">
                  <%= tp.person? ? "Persona" : "Empresa" %>
                </span>
              </td>
              <td class="px-4 py-3 text-gray-600">
                <span class="text-xs text-gray-500"><%= tp.document_type_label %>:</span>
                <%= tp.document_number %>
              </td>
              <td class="px-4 py-3 text-gray-600"><%= tp.phone %></td>
              <td class="px-4 py-3 text-center flex justify-center gap-3">
                <%= link_to "Editar", edit_third_party_path(tp),
                            class: "text-xs text-blue-600 hover:underline" %>
                <%= button_to "Eliminar", third_party_path(tp), method: :delete,
                              class: "text-xs text-red-600 hover:underline bg-transparent border-0 cursor-pointer",
                              form: { onsubmit: "return confirm('¿Está seguro de que desea eliminar este tercero?')" } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="text-center py-16 text-gray-500" x-data>
      <p class="text-lg font-medium">No tienes terceros registrados.</p>
      <button @click="open = true" class="mt-4 inline-block text-blue-600 hover:underline text-sm">
        Registrar primer tercero
      </button>
    </div>
  <% end %>
</div>