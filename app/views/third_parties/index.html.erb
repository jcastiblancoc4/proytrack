<div class="max-w-5xl mx-auto px-4 mt-6" x-data="{ open: <%= @third_party&.errors&.any? ? 'true' : 'false' %> }">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Terceros</h1>
    <button @click="open = true"
            class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-4 py-2 rounded">
      Nuevo Tercero
    </button>
  </div>

  <!-- Modal -->
  <div x-show="open"
       x-transition:enter="transition ease-out duration-200"
       x-transition:enter-start="opacity-0"
       x-transition:enter-end="opacity-100"
       x-transition:leave="transition ease-in duration-150"
       x-transition:leave-start="opacity-100"
       x-transition:leave-end="opacity-0"
       class="fixed inset-0 z-50 flex items-center justify-center bg-black/50"
       style="display: none;">
    <div @click.outside="open = false"
         class="bg-white rounded-xl shadow-xl w-full max-w-lg mx-4 p-6 max-h-[90vh] overflow-y-auto">
      <div class="flex justify-between items-center mb-5">
        <h2 class="text-lg font-bold text-gray-900">Nuevo Tercero</h2>
        <button @click="open = false" class="text-gray-400 hover:text-gray-600">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <%= render "form", third_party: @third_party || ThirdParty.new %>
    </div>
  </div>

  <% if @third_parties.any? %>
    <div class="bg-white rounded-xl shadow border border-gray-100 overflow-hidden">
      <!-- Tabla (escritorio) -->
      <div class="hidden sm:block overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 text-gray-600 uppercase text-xs">
            <tr>
              <th class="px-4 py-3 text-left">Nombre / Razón Social</th>
              <th class="px-4 py-3 text-left">Tipo</th>
              <th class="px-4 py-3 text-left">Documento</th>
              <th class="px-4 py-3 text-left">Contacto</th>
              <th class="px-4 py-3 text-center">Acciones</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @third_parties.each do |tp| %>
              <tr class="hover:bg-gray-50">
                <td class="px-4 py-3 font-medium text-gray-800"><%= tp.full_name %></td>
                <td class="px-4 py-3">
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                    <%= tp.person? ? 'bg-blue-100 text-blue-800' : 'bg-purple-100 text-purple-800' %>">
                    <%= tp.person? ? "Persona" : "Empresa" %>
                  </span>
                </td>
                <td class="px-4 py-3 text-gray-600">
                  <span class="text-xs text-gray-500"><%= tp.document_type_label %>:</span>
                  <%= tp.document_number %>
                </td>
                <td class="px-4 py-3 text-gray-600"><%= tp.phone %></td>
                <td class="px-4 py-3 text-center">
                  <div class="flex justify-center gap-3">
                    <%= link_to "Editar", edit_third_party_path(tp),
                                class: "text-xs text-blue-600 hover:underline" %>
                    <%= button_to "Eliminar", third_party_path(tp), method: :delete,
                                  class: "text-xs text-red-600 hover:underline bg-transparent border-0 cursor-pointer",
                                  form: { onsubmit: "return confirm('¿Está seguro de que desea eliminar este tercero?')" } %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <!-- Tarjetas (móvil) -->
      <div class="sm:hidden divide-y divide-gray-100">
        <% @third_parties.each do |tp| %>
          <div class="px-4 py-4 hover:bg-gray-50 transition-colors">
            <div class="flex items-start gap-3">
              <!-- Avatar inicial -->
              <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0 text-sm font-bold
                <%= tp.person? ? 'bg-blue-100 text-blue-700' : 'bg-purple-100 text-purple-700' %>">
                <%= tp.full_name.first.upcase %>
              </div>

              <div class="flex-1 min-w-0">
                <!-- Nombre + badge tipo -->
                <div class="flex items-center gap-2 flex-wrap">
                  <p class="text-sm font-semibold text-gray-800 leading-snug"><%= tp.full_name %></p>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                    <%= tp.person? ? 'bg-blue-100 text-blue-700' : 'bg-purple-100 text-purple-700' %>">
                    <%= tp.person? ? "Persona" : "Empresa" %>
                  </span>
                </div>

                <!-- Documento -->
                <p class="text-xs text-gray-500 mt-1">
                  <span class="font-medium"><%= tp.document_type_label %>:</span> <%= tp.document_number %>
                </p>

                <!-- Teléfono -->
                <% if tp.phone.present? %>
                  <p class="text-xs text-gray-500 mt-0.5 flex items-center gap-1">
                    <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                    </svg>
                    <%= tp.phone %>
                  </p>
                <% end %>

                <!-- Acciones -->
                <div class="flex items-center gap-2 mt-2.5">
                  <%= link_to edit_third_party_path(tp),
                              class: "inline-flex items-center gap-1 text-xs text-blue-600 bg-blue-50 hover:bg-blue-100 px-2.5 py-1 rounded-full transition-colors" do %>
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
                    </svg>
                    Editar
                  <% end %>
                  <%= button_to third_party_path(tp), method: :delete,
                                class: "inline-flex items-center gap-1 text-xs text-red-600 bg-red-50 hover:bg-red-100 px-2.5 py-1 rounded-full transition-colors border-0 cursor-pointer",
                                form: { onsubmit: "return confirm('¿Está seguro de que desea eliminar este tercero?')" } do %>
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                    Eliminar
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="text-center py-16 text-gray-500" x-data>
      <p class="text-lg font-medium">No tienes terceros registrados.</p>
      <button @click="open = true" class="mt-4 inline-block text-blue-600 hover:underline text-sm">
        Registrar primer tercero
      </button>
    </div>
  <% end %>
</div>