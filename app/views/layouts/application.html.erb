<!DOCTYPE html>
<html>
  <head>
    <title>Proytrack</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>

  </head>

  <body class="bg-gray-100">
  <div id="flash-messages" class="fixed top-4 left-1/2 transform -translate-x-1/2 z-50 w-full max-w-md px-4">
    <% flash.each do |type, message| %>
      <% flash_class =
           case type.to_sym
           when :notice then "bg-green-100 text-green-800 border-green-300"
           when :alert then "bg-red-100 text-red-800 border-red-300"
           when :error then "bg-yellow-100 text-yellow-800 border-yellow-300"
           else "bg-gray-100 text-gray-800 border-gray-300"
           end
      %>
      <div class="flash-alert border-l-4 p-4 mb-3 rounded shadow-sm transition-opacity duration-300 opacity-100 <%= flash_class %>">
        <p class="text-sm font-medium"><%= message %></p>
      </div>
    <% end %>
  </div>


  <% if user_signed_in? %>
    <header class="bg-white shadow" x-data="{ open: false }">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <!-- Barra principal -->
        <div class="flex justify-between items-center py-3 sm:py-4">
          <!-- Logo -->
          <%= link_to "ProyTrack", root_path, class: "text-xl sm:text-3xl font-bold text-blue-700 hover:underline flex-shrink-0" %>

          <!-- Navegación escritorio -->
          <nav class="hidden lg:flex items-center space-x-1">
            <%= link_to root_path, class: "inline-flex items-center gap-1.5 px-3 py-2 text-sm font-medium rounded-md transition-colors #{current_page?(root_path) ? 'bg-blue-100 text-blue-700' : 'text-gray-700 hover:bg-gray-100'}" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path></svg>
              Proyectos
            <% end %>
            <%= link_to accounts_path, class: "inline-flex items-center gap-1.5 px-3 py-2 text-sm font-medium rounded-md transition-colors #{request.path.start_with?('/accounts') ? 'bg-emerald-100 text-emerald-700' : 'text-gray-700 hover:bg-gray-100'}" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
              Cuentas
            <% end %>
            <%= link_to expenses_path, class: "inline-flex items-center gap-1.5 px-3 py-2 text-sm font-medium rounded-md transition-colors #{request.path.start_with?('/expenses') ? 'bg-yellow-100 text-yellow-700' : 'text-gray-700 hover:bg-gray-100'}" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
              Gastos
            <% end %>
            <%= link_to settlements_path, class: "inline-flex items-center gap-1.5 px-3 py-2 text-sm font-medium rounded-md transition-colors #{request.path.start_with?('/settlements') ? 'bg-purple-100 text-purple-700' : 'text-gray-700 hover:bg-gray-100'}" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              Liquidaciones
            <% end %>
            <%= link_to third_parties_path, class: "inline-flex items-center gap-1.5 px-3 py-2 text-sm font-medium rounded-md transition-colors #{request.path.start_with?('/third_parties') ? 'bg-orange-100 text-orange-700' : 'text-gray-700 hover:bg-gray-100'}" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              Terceros
            <% end %>
          </nav>

          <!-- Usuario + Cerrar sesión (escritorio) -->
          <div class="hidden lg:flex items-center space-x-3">
            <div class="flex items-center gap-2 px-3 py-1.5 bg-gray-50 border border-gray-200 rounded-lg text-sm">
              <svg class="w-4 h-4 text-blue-600 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5.121 17.804A7 7 0 0112 15a7 7 0 016.879 2.804M15 10a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span class="font-medium text-gray-900 truncate max-w-[160px]"><%= current_user.email %></span>
            </div>
            <%= button_to "Cerrar sesión", destroy_user_session_path,
                          method: :delete,
                          class: "text-white bg-blue-600 hover:bg-blue-700 text-sm font-medium px-3 py-1.5 rounded transition-colors whitespace-nowrap",
                          form_class: "inline" %>
          </div>

          <!-- Botón hamburguesa (móvil) -->
          <button @click="open = !open" type="button"
                  class="lg:hidden inline-flex items-center justify-center p-2 rounded-md text-gray-600 hover:text-gray-900 hover:bg-gray-100 transition-colors"
                  aria-label="Abrir menú">
            <svg x-show="!open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
            <svg x-show="open" x-cloak class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Menú móvil desplegable -->
      <div x-show="open" x-cloak
           x-transition:enter="transition ease-out duration-150"
           x-transition:enter-start="opacity-0 -translate-y-1"
           x-transition:enter-end="opacity-100 translate-y-0"
           x-transition:leave="transition ease-in duration-100"
           x-transition:leave-start="opacity-100 translate-y-0"
           x-transition:leave-end="opacity-0 -translate-y-1"
           class="lg:hidden border-t border-gray-200 bg-white overflow-y-auto max-h-[calc(100vh-4rem)]">
        <div class="px-4 pt-2 pb-3 space-y-1">
          <%= link_to root_path, class: "flex items-center gap-3 px-3 py-2.5 rounded-md text-sm font-medium transition-colors #{current_page?(root_path) ? 'bg-blue-100 text-blue-700' : 'text-gray-700 hover:bg-gray-100'}" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path></svg>
            Proyectos
          <% end %>
          <%= link_to accounts_path, class: "flex items-center gap-3 px-3 py-2.5 rounded-md text-sm font-medium transition-colors #{request.path.start_with?('/accounts') ? 'bg-emerald-100 text-emerald-700' : 'text-gray-700 hover:bg-gray-100'}" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
            Cuentas
          <% end %>
          <%= link_to expenses_path, class: "flex items-center gap-3 px-3 py-2.5 rounded-md text-sm font-medium transition-colors #{request.path.start_with?('/expenses') ? 'bg-yellow-100 text-yellow-700' : 'text-gray-700 hover:bg-gray-100'}" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
            Gastos
          <% end %>
          <%= link_to settlements_path, class: "flex items-center gap-3 px-3 py-2.5 rounded-md text-sm font-medium transition-colors #{request.path.start_with?('/settlements') ? 'bg-purple-100 text-purple-700' : 'text-gray-700 hover:bg-gray-100'}" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            Liquidaciones
          <% end %>
          <%= link_to third_parties_path, class: "flex items-center gap-3 px-3 py-2.5 rounded-md text-sm font-medium transition-colors #{request.path.start_with?('/third_parties') ? 'bg-orange-100 text-orange-700' : 'text-gray-700 hover:bg-gray-100'}" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            Terceros
          <% end %>
        </div>
        <!-- Usuario y cerrar sesión en móvil -->
        <div class="px-4 pt-3 pb-4 border-t border-gray-200">
          <div class="flex items-center gap-2 mb-3 px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg">
            <svg class="w-5 h-5 text-blue-600 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5.121 17.804A7 7 0 0112 15a7 7 0 016.879 2.804M15 10a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-sm font-medium text-gray-900 truncate"><%= current_user.email %></span>
          </div>
          <%= button_to "Cerrar sesión", destroy_user_session_path,
                        method: :delete,
                        class: "w-full text-white bg-blue-600 hover:bg-blue-700 text-sm font-medium px-3 py-2 rounded transition-colors text-center",
                        form_class: "block" %>
        </div>
      </div>
    </header>

  <% end %>
  <main>
    <%= yield %>
  </main>
  </body>
</html>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const alerts = document.querySelectorAll(".flash-alert");
        alerts.forEach(alert => {
            setTimeout(() => {
                alert.classList.add("opacity-0");
                setTimeout(() => alert.remove(), 500);
            }, 3000); // Oculta después de 3 segundos
        });
    });
</script>
