<!DOCTYPE html>
<html>
  <head>
    <title>Proytrack</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>

  </head>

  <body class="bg-gray-100">
  <div id="flash-messages" class="fixed top-4 left-1/2 transform -translate-x-1/2 z-50 w-full max-w-md px-4">
    <% flash.each do |type, message| %>
      <% flash_class =
           case type.to_sym
           when :notice then "bg-green-100 text-green-800 border-green-300"
           when :alert then "bg-red-100 text-red-800 border-red-300"
           when :error then "bg-yellow-100 text-yellow-800 border-yellow-300"
           else "bg-gray-100 text-gray-800 border-gray-300"
           end
      %>
      <div class="flash-alert border-l-4 p-4 mb-3 rounded shadow-sm transition-opacity duration-300 opacity-100 <%= flash_class %>">
        <p class="text-sm font-medium"><%= message %></p>
      </div>
    <% end %>
  </div>


  <% if user_signed_in? %>
    <%
      user_initials = current_user.email.split("@").first.upcase.first(2)
      nav_items = [
        { label: "Inicio",        path: root_path,          active: current_page?(root_path),                              icon: "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" },
        { label: "Proyectos",     path: projects_path,      active: request.path.start_with?("/projects"),                 icon: "M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" },
        { label: "Cuentas",       path: accounts_path,      active: request.path.start_with?("/accounts"),                 icon: "M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" },
        { label: "Gastos",        path: expenses_path,      active: request.path.start_with?("/expenses"),                 icon: "M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" },
        { label: "Liquidaciones", path: settlements_path,   active: request.path.start_with?("/settlements"),              icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" },
        { label: "Terceros",      path: third_parties_path,    active: request.path.start_with?("/third_parties"),     icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" },
        { label: "Inspecciones",  path: inspection_forms_path, active: request.path.start_with?("/inspection_forms"), icon: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2M9 12h6m-6 4h4" },
      ]
    %>

    <header x-data="{ open: false, userOpen: false }" style="background: linear-gradient(135deg, #0f3d22 0%, #1a6b3a 100%)">

      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="flex items-center justify-between h-16">

          <!-- Logo -->
          <%= link_to root_path, class: "flex items-center gap-2.5 flex-shrink-0" do %>
            <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-white/15">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
              </svg>
            </div>
            <span class="text-lg font-bold tracking-tight text-white">ProyTrack</span>
          <% end %>

          <!-- Navegación escritorio -->
          <nav class="hidden lg:flex items-center gap-1">
            <% nav_items.each do |item| %>
              <%= link_to item[:path],
                    class: "inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium transition-all #{item[:active] ? 'bg-white text-green-900 shadow-sm' : 'text-white/75 hover:text-white hover:bg-white/15'}" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= item[:icon] %>"/>
                </svg>
                <%= item[:label] %>
              <% end %>
            <% end %>
          </nav>

          <!-- Usuario (escritorio) -->
          <div class="hidden lg:flex items-center relative" @click.away="userOpen = false">
            <button @click="userOpen = !userOpen"
                    class="flex items-center gap-2 px-2.5 py-1.5 rounded-lg transition-all hover:bg-white/15">
              <div class="w-8 h-8 rounded-full flex items-center justify-center text-green-900 text-xs font-bold bg-white flex-shrink-0">
                <%= user_initials %>
              </div>
              <span class="text-sm font-medium text-white/90 max-w-[120px] truncate"><%= current_user.email.split("@").first %></span>
              <svg class="w-4 h-4 text-white/60 transition-transform" :class="userOpen ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>

            <!-- Dropdown usuario -->
            <div x-show="userOpen" x-cloak
                 x-transition:enter="transition ease-out duration-100"
                 x-transition:enter-start="opacity-0 scale-95"
                 x-transition:enter-end="opacity-100 scale-100"
                 x-transition:leave="transition ease-in duration-75"
                 x-transition:leave-start="opacity-100 scale-100"
                 x-transition:leave-end="opacity-0 scale-95"
                 class="absolute right-0 top-12 w-56 bg-white rounded-xl shadow-xl border border-gray-100 z-50 overflow-hidden">
              <div class="px-4 py-3 border-b border-gray-100" style="background: linear-gradient(135deg, #0f3d22, #1a6b3a)">
                <p class="text-xs text-white/60">Sesión iniciada como</p>
                <p class="text-sm font-semibold text-white truncate"><%= current_user.email %></p>
              </div>
              <div class="p-2">
                <%= button_to "Cerrar sesión", destroy_user_session_path,
                      method: :delete,
                      class: "w-full text-left px-3 py-2 text-sm text-red-600 hover:bg-red-50 rounded-lg transition-colors font-medium",
                      form_class: "block" %>
              </div>
            </div>
          </div>

          <!-- Botón hamburguesa (móvil) -->
          <button @click="open = !open" type="button"
                  class="lg:hidden inline-flex items-center justify-center p-2 rounded-lg text-white/80 hover:text-white hover:bg-white/15 transition-colors"
                  aria-label="Abrir menú">
            <svg x-show="!open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
            <svg x-show="open" x-cloak class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>

        </div>
      </div>

      <!-- Menú móvil -->
      <div x-show="open" x-cloak
           x-transition:enter="transition ease-out duration-150"
           x-transition:enter-start="opacity-0 -translate-y-1"
           x-transition:enter-end="opacity-100 translate-y-0"
           x-transition:leave="transition ease-in duration-100"
           x-transition:leave-start="opacity-100 translate-y-0"
           x-transition:leave-end="opacity-0 -translate-y-1"
           class="lg:hidden bg-white border-t border-white/10 shadow-xl">

        <!-- Usuario -->
        <div class="flex items-center gap-3 px-4 py-3 border-b border-gray-100" style="background: linear-gradient(135deg, #0f3d22, #1a6b3a)">
          <div class="w-9 h-9 rounded-full flex items-center justify-center text-green-900 text-sm font-bold bg-white flex-shrink-0">
            <%= user_initials %>
          </div>
          <div class="min-w-0">
            <p class="text-sm font-semibold text-white truncate"><%= current_user.email.split("@").first.capitalize %></p>
            <p class="text-xs text-white/60 truncate"><%= current_user.email %></p>
          </div>
        </div>

        <!-- Links de navegación -->
        <div class="px-3 py-2 space-y-0.5">
          <% nav_items.each do |item| %>
            <%= link_to item[:path],
                  class: "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors #{item[:active] ? 'text-green-800 font-semibold' : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900'}",
                  style: item[:active] ? 'background-color: #dcfce7' : '' do %>
              <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= item[:icon] %>"/>
              </svg>
              <%= item[:label] %>
            <% end %>
          <% end %>
        </div>

        <!-- Cerrar sesión -->
        <div class="px-3 pb-3 pt-1 border-t border-gray-100">
          <%= button_to "Cerrar sesión", destroy_user_session_path,
                method: :delete,
                class: "w-full text-left px-3 py-2.5 rounded-lg text-sm font-medium text-red-600 hover:bg-red-50 transition-colors",
                form_class: "block" %>
        </div>

      </div>
    </header>

  <% end %>
  <main>
    <%= yield %>
  </main>
  </body>
</html>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const alerts = document.querySelectorAll(".flash-alert");
        alerts.forEach(alert => {
            setTimeout(() => {
                alert.classList.add("opacity-0");
                setTimeout(() => alert.remove(), 500);
            }, 3000); // Oculta después de 3 segundos
        });
    });
</script>
