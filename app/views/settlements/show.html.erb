<div class="max-w-7xl mx-auto px-3 sm:px-4 mt-4">
  <div class="mb-6">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center mb-6 gap-3">
      <div>
        <h1 class="text-xl sm:text-2xl font-extrabold text-blue-900">
          💰 Liquidación <%= @settlement.period_name %>
        </h1>
        <p class="text-xs sm:text-sm text-gray-600 mt-1">
          Creada el <%= @settlement.created_at.in_time_zone("Bogota").strftime("%d/%m/%Y %I:%M %p") %>
        </p>
      </div>

      <div class="flex gap-2">
        <%= link_to "Volver", settlements_path, class: "inline-flex items-center px-4 py-2 bg-gray-600 text-white text-sm font-semibold rounded hover:bg-gray-700 transition-colors duration-200" %>
      </div>
    </div>

    <!-- Resumen de Totales -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
      <div class="bg-green-50 border-2 border-green-200 rounded-lg p-6">
        <h3 class="text-sm font-medium text-green-800 mb-2">Total Proyectos</h3>
        <p class="text-3xl font-bold text-green-600">
          <%= number_to_currency(@settlement.total_projects_value, unit: "$", delimiter: ".", separator: ",", precision: 0) %>
        </p>
        <p class="text-xs text-green-600 mt-1"><%= @projects.count %> <%= @projects.count == 1 ? 'proyecto' : 'proyectos' %></p>
      </div>

      <div class="bg-red-50 border-2 border-red-200 rounded-lg p-6">
        <h3 class="text-sm font-medium text-red-800 mb-2">Total Gastos</h3>
        <p class="text-3xl font-bold text-red-600">
          <%= number_to_currency(@settlement.total_expenses_value, unit: "$", delimiter: ".", separator: ",", precision: 0) %>
        </p>
        <p class="text-xs text-red-600 mt-1"><%= @expenses.count %> <%= @expenses.count == 1 ? 'gasto' : 'gastos' %></p>
      </div>

      <div class="<%= @settlement.difference >= 0 ? 'bg-blue-50 border-2 border-blue-200' : 'bg-orange-50 border-2 border-orange-200' %> rounded-lg p-6">
        <h3 class="text-sm font-medium <%= @settlement.difference >= 0 ? 'text-blue-800' : 'text-orange-800' %> mb-2">Utilidad</h3>
        <p class="text-3xl font-bold <%= @settlement.difference >= 0 ? 'text-blue-600' : 'text-orange-600' %>">
          <%= number_to_currency(@settlement.difference, unit: "$", delimiter: ".", separator: ",", precision: 0) %>
        </p>
        <p class="text-xs <%= @settlement.difference >= 0 ? 'text-blue-600' : 'text-orange-600' %> mt-1">
          <%= @settlement.difference >= 0 ? 'Superávit' : 'Déficit' %>
        </p>
      </div>
    </div>

    <!-- Sección de usuarios con acceso a la liquidación -->
    <% if @can_edit %>
      <div class="bg-white shadow rounded-lg mb-6">
        <!-- Header con título y botón para agregar -->
        <div class="px-6 py-4 border-b border-gray-200">
          <div class="flex items-center justify-between">
            <div class="flex items-center">
              <svg class="w-5 h-5 mr-2 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
              <h2 class="text-lg font-medium text-gray-900">
                Usuarios con Acceso
              </h2>
              <span class="ml-2 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                <%= @settlement.shared_settlements.count %>
              </span>
            </div>
            <button type="button" onclick="toggleShareModal()" class="inline-flex items-center px-3 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-colors">
              <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path>
              </svg>
              Compartir Liquidación
            </button>
          </div>
        </div>

        <!-- Lista de usuarios con acceso -->
        <div class="px-6 py-4">
          <% if @settlement.shared_settlements.any? %>
            <div class="space-y-2">
              <% @settlement.shared_settlements.includes(:user, :shared_by).each do |shared_settlement| %>
                <div class="flex items-center justify-between p-4 bg-white rounded-lg border border-gray-200 hover:border-blue-300 hover:bg-blue-50/30 transition-all duration-200">
                  <div class="flex items-center space-x-3 flex-1">
                    <div class="flex-shrink-0">
                      <div class="w-10 h-10 bg-blue-500 rounded-full flex items-center justify-center">
                        <span class="text-white font-semibold text-sm"><%= shared_settlement.user.email[0].upcase %></span>
                      </div>
                    </div>
                    <div class="flex-1">
                      <p class="text-sm font-semibold text-gray-900"><%= shared_settlement.user.email %></p>
                      <div class="flex items-center space-x-2 mt-0.5">
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-700">
                          Solo lectura
                        </span>
                        <span class="text-xs text-gray-500">
                          • <%= time_ago_in_words(shared_settlement.created_at) %>
                        </span>
                      </div>
                    </div>
                  </div>
                  <button onclick="if(confirm('¿Revocar acceso a <%= shared_settlement.user.email %>?')) { document.getElementById('revoke-<%= shared_settlement.id %>').submit(); }"
                          class="inline-flex items-center gap-1.5 px-3 py-2 text-sm font-medium rounded-md text-red-600 bg-red-50 border border-red-200 hover:bg-red-100 hover:border-red-300 hover:text-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-1 transition-all duration-200">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                    </svg>
                    <span>Quitar</span>
                  </button>
                  <%= form_with url: settlement_shared_settlement_path(@settlement, shared_settlement), method: :delete, local: true, html: { id: "revoke-#{shared_settlement.id}", style: "display: none;" } do |f| %>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="text-center py-6 text-gray-500 text-sm">
              No has compartido esta liquidación con ningún usuario aún.
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Proyectos Liquidados -->
    <div class="mb-6">
      <h2 class="text-lg font-bold text-gray-800 mb-4">🏗️ Proyectos en Liquidación</h2>
      <% if @projects.any? %>
        <div class="bg-white rounded-lg shadow overflow-hidden">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Proyecto</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">ID</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Fecha Liquidación</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Estado</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Valor Cotizado</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @projects.each do |project| %>
                <tr class="hover:bg-gray-50">
                  <td class="px-6 py-4 text-sm font-medium text-gray-900">
                    <%= link_to project.name, project_path(project), class: "text-blue-600 hover:text-blue-800" %>
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-500"><%= project.project_identifier %></td>
                  <td class="px-6 py-4 text-sm text-gray-500">
                    <%= project.settlement_date.strftime("%d/%m/%Y") if project.settlement_date %>
                  </td>
                  <td class="px-6 py-4 text-sm">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                      💰 <%= t("enums.project.execution_status.#{project.execution_status}") %>
                    </span>
                  </td>
                  <td class="px-6 py-4 text-sm text-right font-semibold text-green-600">
                    <%= number_to_currency(project.quoted_value, unit: "$", delimiter: ".", separator: ",", precision: 0) %>
                  </td>
                </tr>
              <% end %>
            </tbody>
            <tfoot class="bg-gray-50">
              <tr>
                <td colspan="4" class="px-6 py-4 text-sm font-bold text-gray-900">Total</td>
                <td class="px-6 py-4 text-sm text-right font-bold text-green-600">
                  <%= number_to_currency(@settlement.total_projects_value, unit: "$", delimiter: ".", separator: ",", precision: 0) %>
                </td>
              </tr>
            </tfoot>
          </table>
        </div>
      <% else %>
        <div class="bg-gray-50 border border-gray-200 rounded-lg p-6 text-center">
          <p class="text-gray-600">No hay proyectos en esta liquidación</p>
        </div>
      <% end %>
    </div>

    <!-- Gastos Liquidados -->
    <div class="mb-6">
      <h2 class="text-lg font-bold text-gray-800 mb-4">💸 Gastos en Liquidación</h2>
      <% if @expenses.any? %>
        <div class="bg-white rounded-lg shadow overflow-hidden">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Proyecto</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">ID Proyecto</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Descripción</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Tipo</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Fecha</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Estado</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Monto</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @expenses.each do |expense| %>
                <tr class="hover:bg-gray-50">
                  <td class="px-6 py-4 text-sm font-medium text-gray-900">
                    <%= link_to expense.project.name, project_path(expense.project), class: "text-blue-600 hover:text-blue-800" %>
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-500"><%= expense.project.project_identifier %></td>
                  <td class="px-6 py-4 text-sm text-gray-500"><%= expense.description.truncate(50) %></td>
                  <td class="px-6 py-4 text-sm text-gray-500">
                    <%= t("enums.expense.expense_type.#{expense.expense_type}") %>
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-500">
                    <%= expense.expense_date.strftime("%d/%m/%Y") if expense.expense_date %>
                  </td>
                  <td class="px-6 py-4 text-sm">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                      <%= t("enums.expense.status.#{expense.status}") %>
                    </span>
                  </td>
                  <td class="px-6 py-4 text-sm text-right font-semibold text-red-600">
                    <%= number_to_currency(expense.amount, unit: "$", delimiter: ".", separator: ",", precision: 0) %>
                  </td>
                </tr>
              <% end %>
            </tbody>
            <tfoot class="bg-gray-50">
              <tr>
                <td colspan="6" class="px-6 py-4 text-sm font-bold text-gray-900">Total</td>
                <td class="px-6 py-4 text-sm text-right font-bold text-red-600">
                  <%= number_to_currency(@settlement.total_expenses_value, unit: "$", delimiter: ".", separator: ",", precision: 0) %>
                </td>
              </tr>
            </tfoot>
          </table>
        </div>
      <% else %>
        <div class="bg-gray-50 border border-gray-200 rounded-lg p-6 text-center">
          <p class="text-gray-600">No hay gastos en esta liquidación</p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Modal para compartir liquidación -->
<% if @can_edit %>
  <div id="shareModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.5); z-index: 9999; overflow-y: auto;">
    <div style="position: relative; margin: 80px auto; padding: 30px; width: 450px; max-width: 90%; background: white; border-radius: 12px; box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);" onclick="event.stopPropagation()">
      <!-- Header del modal -->
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 2px solid #e5e7eb;">
        <div style="display: flex; align-items: center; gap: 10px;">
          <svg style="width: 24px; height: 24px; color: #16a34a;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.645 9 12 9 12s.114.645.316 1.342m0 0a8.997 8.997 0 001.656 2.658m-1.656-2.658a8.997 8.997 0 01-1.656-2.658m0 0a8.997 8.997 0 011.656-2.658m-1.656 2.658L9 12l1.656-2.658m0 0a8.997 8.997 0 011.656 2.658m-1.656-2.658L9 12l-1.656 2.658"></path>
          </svg>
          <h3 style="font-size: 20px; font-weight: 600; color: #111827; margin: 0;">Compartir Liquidación</h3>
        </div>
        <button type="button" onclick="closeShareModal()" style="background: none; border: none; cursor: pointer; color: #9ca3af; padding: 4px; border-radius: 4px; transition: all 0.2s;" onmouseover="this.style.color='#4b5563'; this.style.backgroundColor='#f3f4f6';" onmouseout="this.style.color='#9ca3af'; this.style.backgroundColor='transparent';">
          <svg style="width: 24px; height: 24px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>

      <%= form_with url: settlement_shared_settlements_path(@settlement), method: :post, local: true do |f| %>
        <div style="margin-bottom: 24px;">
          <label for="shared_settlement_user_email" style="display: flex; align-items: center; gap: 6px; font-size: 14px; font-weight: 500; color: #374151; margin-bottom: 8px;">
            Email del usuario
            <div style="position: relative; display: inline-block;">
              <svg class="info-icon" style="width: 16px; height: 16px; color: #6b7280; cursor: help;" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
              </svg>
              <div class="tooltip-text" style="visibility: hidden; opacity: 0; position: absolute; bottom: 125%; left: 50%; transform: translateX(-50%); width: 250px; background-color: #1f2937; color: white; text-align: center; padding: 8px 12px; border-radius: 6px; font-size: 12px; font-weight: normal; z-index: 10000; transition: opacity 0.3s, visibility 0.3s; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.2);">
                El usuario podrá ver la liquidación y sus detalles, pero no podrá editarla ni eliminarla.
                <div style="position: absolute; top: 100%; left: 50%; margin-left: -5px; border-width: 5px; border-style: solid; border-color: #1f2937 transparent transparent transparent;"></div>
              </div>
            </div>
          </label>
          <%= f.email_field :email,
              id: "shared_settlement_user_email",
              placeholder: "ejemplo@correo.com",
              required: true,
              style: "width: 100%; padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 14px; transition: all 0.2s; outline: none;",
              onfocus: "this.style.borderColor='#3b82f6'; this.style.boxShadow='0 0 0 3px rgba(59, 130, 246, 0.1)';",
              onblur: "this.style.borderColor='#d1d5db'; this.style.boxShadow='none';" %>
        </div>

        <div style="display: flex; justify-content: flex-end; gap: 12px; margin-top: 24px; padding-top: 20px; border-top: 1px solid #e5e7eb;">
          <button type="button" onclick="closeShareModal()"
                  style="padding: 10px 20px; font-size: 14px; font-weight: 500; color: #374151; background-color: #f9fafb; border: 1px solid #d1d5db; border-radius: 6px; cursor: pointer; transition: all 0.2s;"
                  onmouseover="this.style.backgroundColor='#f3f4f6';"
                  onmouseout="this.style.backgroundColor='#f9fafb';">
            Cancelar
          </button>
          <%= f.submit "Compartir Liquidación",
              style: "padding: 10px 24px; font-size: 14px; font-weight: 500; color: white; background-color: #16a34a; border: none; border-radius: 6px; cursor: pointer; transition: all 0.2s;",
              onmouseover: "this.style.backgroundColor='#15803d';",
              onmouseout: "this.style.backgroundColor='#16a34a';" %>
        </div>
      <% end %>
    </div>
  </div>

  <script>
    // Funciones para el modal de compartir liquidación
    function toggleShareModal() {
      const modal = document.getElementById('shareModal');

      if (!modal) {
        console.error('Modal element not found!');
        alert('Error: No se pudo encontrar el modal');
        return;
      }

      const currentDisplay = window.getComputedStyle(modal).display;

      if (currentDisplay === 'none' || modal.style.display === 'none') {
        modal.style.display = 'block';
        modal.style.visibility = 'visible';
        modal.style.opacity = '1';
      } else {
        modal.style.display = 'none';
      }
    }

    function closeShareModal() {
      const modal = document.getElementById('shareModal');
      if (modal) {
        modal.style.display = 'none';
      }
    }

    // Cerrar modal al hacer clic fuera de él
    document.addEventListener('DOMContentLoaded', function() {
      const modal = document.getElementById('shareModal');
      if (modal) {
        modal.addEventListener('click', function(event) {
          if (event.target === modal) {
            closeShareModal();
          }
        });
      }

      // Tooltip para el icono de información
      const infoIcons = document.querySelectorAll('.info-icon');
      infoIcons.forEach(icon => {
        const tooltip = icon.nextElementSibling;
        if (tooltip) {
          icon.addEventListener('mouseenter', () => {
            tooltip.style.visibility = 'visible';
            tooltip.style.opacity = '1';
          });
          icon.addEventListener('mouseleave', () => {
            tooltip.style.visibility = 'hidden';
            tooltip.style.opacity = '0';
          });
        }
      });
    });
  </script>
<% end %>
