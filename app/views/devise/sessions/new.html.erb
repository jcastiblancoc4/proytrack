<div class="min-h-screen flex">

  <!-- Panel izquierdo: branding MC Ingenieros (solo desktop) -->
  <div class="hidden lg:flex lg:w-1/2 flex-col justify-between p-12 text-white relative overflow-hidden"
       style="background: linear-gradient(150deg, #0f3d22 0%, #1a6b3a 50%, #22c15e 100%)">

    <!-- Círculos decorativos de fondo -->
    <div class="absolute top-0 right-0 w-96 h-96 rounded-full opacity-10"
         style="background: radial-gradient(circle, #ffffff, transparent); transform: translate(30%, -30%)"></div>
    <div class="absolute bottom-0 left-0 w-72 h-72 rounded-full opacity-10"
         style="background: radial-gradient(circle, #ffffff, transparent); transform: translate(-30%, 30%)"></div>

    <!-- Logo + nombre empresa -->
    <div class="relative z-10">
      <%= image_tag "mc_ingenieros_logo.png",
            alt: "MC Ingenieros SAS",
            class: "h-16 w-auto mb-10 brightness-0 invert" %>

      <h2 class="text-4xl font-bold leading-tight mb-4">
        Gestión inteligente<br>de tus proyectos
      </h2>
      <p class="text-white/70 text-lg leading-relaxed">
        Control total sobre proyectos, gastos y equipos.<br>
        Todo en un solo lugar.
      </p>
    </div>

    <!-- Stats empresa -->
    <div class="relative z-10 grid grid-cols-2 gap-4">
      <div class="rounded-2xl p-5" style="background: rgba(255,255,255,0.12)">
        <p class="text-4xl font-extrabold">120<span class="text-2xl">+</span></p>
        <p class="text-sm text-white/70 mt-1">Toneladas gestionadas</p>
      </div>
      <div class="rounded-2xl p-5" style="background: rgba(255,255,255,0.12)">
        <p class="text-4xl font-extrabold">90<span class="text-2xl">+</span></p>
        <p class="text-sm text-white/70 mt-1">Eventos ambientales atendidos</p>
      </div>
    </div>
  </div>

  <!-- Panel derecho: formulario -->
  <div class="flex-1 flex items-center justify-center p-6 bg-gray-50">
    <div class="w-full max-w-md">

      <!-- Logo en móvil -->
      <div class="lg:hidden text-center mb-8">
        <%= image_tag "mc_ingenieros_logo.png", alt: "MC Ingenieros SAS", class: "h-12 w-auto mx-auto mb-4" %>
      </div>

      <!-- Encabezado del formulario -->
      <div class="mb-8">
        <p class="text-sm font-semibold uppercase tracking-widest mb-1" style="color: #22c15e">ProyTrack</p>
        <h1 class="text-3xl font-bold text-gray-900">Bienvenido de vuelta</h1>
        <p class="text-gray-500 text-sm mt-2">Ingresa tus credenciales para continuar</p>
      </div>

      <!-- Formulario -->
      <%= form_with(scope: :user, url: session_path(:user), class: "space-y-5") do |f| %>

        <div>
          <%= f.label :email, "Correo electrónico", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email, autofocus: true, required: true,
                            placeholder: "tucorreo@ejemplo.com",
                            class: "block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm shadow-sm transition focus:outline-none focus:ring-2",
                            style: "focus-ring-color: #22c15e",
                            onfocus: "this.style.borderColor='#22c15e'; this.style.boxShadow='0 0 0 3px rgba(34,193,94,0.15)'",
                            onblur:  "this.style.borderColor=''; this.style.boxShadow=''" %>
        </div>

        <div>
          <%= f.label :password, "Contraseña", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :password, autocomplete: "current-password", required: true,
                               placeholder: "••••••••",
                               class: "block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm shadow-sm transition focus:outline-none focus:ring-2",
                               onfocus: "this.style.borderColor='#22c15e'; this.style.boxShadow='0 0 0 3px rgba(34,193,94,0.15)'",
                               onblur:  "this.style.borderColor=''; this.style.boxShadow=''" %>
        </div>

        <div class="flex items-center justify-between">
          <% if devise_mapping.rememberable? %>
            <div class="flex items-center gap-2">
              <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-gray-300", style: "accent-color: #22c15e" %>
              <%= f.label :remember_me, "Recordarme", class: "text-sm text-gray-600" %>
            </div>
          <% end %>
          <%= link_to "¿Olvidaste tu contraseña?", new_password_path(resource_name),
                      class: "text-sm hover:underline", style: "color: #22c15e" %>
        </div>

        <div>
          <%= f.submit "Iniciar Sesión",
                       class: "w-full text-white font-semibold py-2.5 rounded-lg transition cursor-pointer",
                       style: "background-color: #22c15e",
                       onmouseover: "this.style.backgroundColor='#1aaa50'",
                       onmouseout:  "this.style.backgroundColor='#22c15e'" %>
        </div>

      <% end %>

      <!-- Registro -->
      <p class="mt-6 text-center text-sm text-gray-500">
        ¿No tienes cuenta?
        <%= link_to "Regístrate aquí", new_registration_path(resource_name),
                    class: "font-semibold hover:underline", style: "color: #22c15e" %>
      </p>

      <!-- Footer -->
      <p class="mt-10 text-center text-xs text-gray-400">
        © <%= Date.current.year %> MC Ingenieros SAS · Ibagué, Tolima
      </p>

    </div>
  </div>

</div>
