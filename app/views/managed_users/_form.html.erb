<%= form_with model: @managed_user, url: form_url, method: form_method, class: "space-y-6" do |f| %>

  <%# Errores del usuario %>
  <% if @managed_user.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-xl p-4">
      <p class="text-sm font-semibold text-red-700 mb-2">Por favor corrige los siguientes errores:</p>
      <ul class="list-disc list-inside space-y-1">
        <% @managed_user.errors.full_messages.each do |msg| %>
          <li class="text-sm text-red-600"><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Errores del perfil %>
  <% if @profile.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-xl p-4">
      <p class="text-sm font-semibold text-red-700 mb-2">Por favor corrige los siguientes errores:</p>
      <ul class="list-disc list-inside space-y-1">
        <% @profile.errors.full_messages.each do |msg| %>
          <li class="text-sm text-red-600"><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Datos de acceso -->
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="px-5 py-3 border-b border-gray-100" style="background: linear-gradient(135deg, #0f3d22, #1a6b3a)">
      <h3 class="text-sm font-semibold text-white">Datos de acceso</h3>
    </div>
    <div class="p-5 grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <%= f.label :email, "Correo electrónico", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email, class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent", placeholder: "correo@ejemplo.com" %>
      </div>
      <div>
        <%= f.label :password, @managed_user.persisted? ? "Nueva contraseña (dejar en blanco para no cambiar)" : "Contraseña", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password, class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent", autocomplete: "new-password" %>
      </div>
      <div>
        <%= f.label :password_confirmation, "Confirmar contraseña", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password_confirmation, class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent", autocomplete: "new-password" %>
      </div>
    </div>
  </div>

  <!-- Perfil del usuario -->
  <%= fields_for :user_profile, @profile do |pf| %>
    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
      <div class="px-5 py-3 border-b border-gray-100" style="background: linear-gradient(135deg, #0f3d22, #1a6b3a)">
        <h3 class="text-sm font-semibold text-white">Perfil del usuario</h3>
      </div>
      <div class="p-5 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <%= pf.label :first_name, "Nombre", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= pf.text_field :first_name, class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent", placeholder: "Nombre" %>
        </div>
        <div>
          <%= pf.label :last_name, "Apellido", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= pf.text_field :last_name, class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent", placeholder: "Apellido" %>
        </div>
        <div>
          <%= pf.label :phone_number, "Número de contacto", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= pf.text_field :phone_number, class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent", placeholder: "300 000 0000" %>
        </div>
        <div>
          <%= pf.label :position_cd, "Cargo", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= pf.select :position_cd,
                [["Inspector", 0], ["Supervisor", 1]],
                { selected: @profile.position_cd },
                class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent" %>
        </div>
      </div>
    </div>
  <% end %>

  <div class="flex items-center justify-end gap-3">
    <%= link_to "Cancelar", managed_users_path, class: "px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors" %>
    <%= f.submit submit_label, class: "px-5 py-2 text-sm font-semibold text-white rounded-lg transition-colors cursor-pointer", style: "background: linear-gradient(135deg, #0f3d22, #1a6b3a)" %>
  </div>

<% end %>
