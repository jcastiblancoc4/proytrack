<%= form_with model: account, class: "space-y-5" do |f| %>
  <% if account.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <ul class="list-disc pl-5 text-sm text-red-700 space-y-1">
        <% account.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, "Nombre de la cuenta", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name,
                     placeholder: "Ej: Cuenta principal, Tarjeta Visa",
                     class: "w-full border border-gray-300 rounded px-3 py-2 focus:ring focus:ring-blue-200" %>
  </div>

  <div>
    <%= f.label :account_type, "Tipo de cuenta", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.select :account_type,
                 Account.account_types.map { |k, _| [t("enums.account.account_type.#{k}"), k] },
                 {},
                 class: "w-full border border-gray-300 rounded px-3 py-2",
                 id: "account_account_type",
                 onchange: "toggleAccountFields()" %>
  </div>

  <!-- Campos para cuentas bancarias y crédito -->
  <div id="bank-field" class="<%= account.requires_bank? ? '' : 'hidden' %>">
    <div class="mb-4">
      <%= f.label :bank_name, "Banco / Entidad", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :bank_name,
                   [["Selecciona un banco", ""]] + Account::BANKS.map { |b| [b, b] },
                   {},
                   class: "w-full border border-gray-300 rounded px-3 py-2" %>
    </div>
    <div id="account-number-field">
      <%= f.label :account_number, "Número de cuenta", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :account_number,
                       placeholder: "Ej: 1234567890",
                       class: "w-full border border-gray-300 rounded px-3 py-2 focus:ring focus:ring-blue-200" %>
    </div>
  </div>

  <!-- Campos específicos de crédito -->
  <div id="credit-fields" class="<%= account.credit? ? '' : 'hidden' %> space-y-4">
    <div>
      <%= f.label :credit_subtype, "Subtipo de crédito", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :credit_subtype,
                   Account.credit_subtypes.map { |k, _| [t("enums.account.credit_subtype.#{k}"), k] },
                   {},
                   class: "w-full border border-gray-300 rounded px-3 py-2" %>
    </div>
    <div>
      <%= f.label :credit_limit, "Cupo total (COP)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <input type="text"
             id="credit_limit_display"
             placeholder="0"
             inputmode="numeric"
             autocomplete="off"
             value="<%= account.credit_limit&.positive? ? number_to_currency(account.credit_limit, unit: '', separator: ',', delimiter: '.', precision: 0).strip : '' %>"
             class="w-full border border-gray-300 rounded px-3 py-2 focus:ring focus:ring-blue-200">
      <%= f.hidden_field :credit_limit, id: "credit_limit_raw" %>
      <p class="text-xs text-gray-500 mt-1">Cupo máximo aprobado de la tarjeta o crédito.</p>
    </div>
  </div>

  <% unless account.persisted? %>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1" id="initial-balance-label">
        <span id="label-regular">Saldo inicial (COP)</span>
        <span id="label-credit" class="hidden">Deuda actual (COP)</span>
      </label>
      <input type="text"
             id="initial_balance_display"
             placeholder="0"
             inputmode="numeric"
             autocomplete="off"
             class="w-full border border-gray-300 rounded px-3 py-2 focus:ring focus:ring-blue-200">
      <%= f.hidden_field :initial_balance, id: "initial_balance_raw" %>
      <p class="text-xs text-gray-500 mt-1" id="initial-balance-hint-regular">Se registrará automáticamente como una transacción de "Saldo inicial".</p>
      <p class="text-xs text-gray-500 mt-1 hidden" id="initial-balance-hint-credit">Si ya tienes deuda en este crédito, ingrésala aquí. Si es una cuenta nueva, deja en 0.</p>
    </div>
  <% end %>

  <div class="flex justify-between items-center pt-2">
    <% if account.persisted? %>
      <%= link_to "Cancelar", account_path(account), class: "text-gray-600 hover:underline text-sm" %>
    <% else %>
      <button type="button" @click="open = false" class="text-gray-600 hover:underline text-sm">Cancelar</button>
    <% end %>
    <%= f.submit account.persisted? ? "Actualizar Cuenta" : "Crear Cuenta",
                 class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded text-sm font-medium" %>
  </div>
<% end %>

<script>
  function toggleAccountFields() {
    const typeSelect   = document.getElementById('account_account_type');
    const bankField    = document.getElementById('bank-field');
    const accountNumField = document.getElementById('account-number-field');
    const creditFields = document.getElementById('credit-fields');
    const labelRegular = document.getElementById('label-regular');
    const labelCredit  = document.getElementById('label-credit');
    const hintRegular  = document.getElementById('initial-balance-hint-regular');
    const hintCredit   = document.getElementById('initial-balance-hint-credit');

    const isCredit   = typeSelect.value === 'credit';
    const needsBank  = typeSelect.value === 'savings' || typeSelect.value === 'checking' || isCredit;

    bankField.classList.toggle('hidden', !needsBank);
    if (creditFields) creditFields.classList.toggle('hidden', !isCredit);

    if (labelRegular) labelRegular.classList.toggle('hidden', isCredit);
    if (labelCredit)  labelCredit.classList.toggle('hidden', !isCredit);
    if (hintRegular)  hintRegular.classList.toggle('hidden', isCredit);
    if (hintCredit)   hintCredit.classList.toggle('hidden', !isCredit);

    if (!needsBank) {
      const bankSelect = bankField.querySelector('select');
      if (bankSelect) bankSelect.value = '';
    }
  }

  // Formateo del saldo/deuda inicial
  (function () {
    const display = document.getElementById('initial_balance_display');
    const raw     = document.getElementById('initial_balance_raw');
    if (!display || !raw) return;
    display.addEventListener('input', function () {
      const digits = this.value.replace(/\D/g, '');
      this.value = digits.replace(/\B(?=(\d{3})+(?!\d))/g, '.');
      raw.value  = digits;
    });
  })();

  // Formateo del cupo de crédito
  (function () {
    const display = document.getElementById('credit_limit_display');
    const raw     = document.getElementById('credit_limit_raw');
    if (!display || !raw) return;
    display.addEventListener('input', function () {
      const digits = this.value.replace(/\D/g, '');
      this.value = digits.replace(/\B(?=(\d{3})+(?!\d))/g, '.');
      raw.value  = digits;
    });
    // Sincronizar valor inicial si ya existe
    if (display.value) {
      const digits = display.value.replace(/\D/g, '');
      raw.value = digits;
    }
  })();
</script>
