<div class="max-w-5xl mx-auto px-4 mt-6 space-y-6">

  <!-- Cabecera de la cuenta -->
  <div class="bg-white rounded-xl shadow p-6 border border-gray-100">
    <div class="flex justify-between items-start">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">
          <%= t("enums.account.account_type.#{@account.account_type}") %>
          <% if @account.credit? %>
            · <%= t("enums.account.credit_subtype.#{@account.credit_subtype}") %>
          <% end %>
          <% if @account.bank_name.present? %> · <%= @account.bank_name %><% end %>
          <% if @account.account_number.present? %> · Nº <%= @account.account_number %><% end %>
        </p>
        <h1 class="text-2xl font-bold text-gray-900 mt-1"><%= @account.name %></h1>
      </div>
      <div class="text-right">
        <% if @account.credit? %>
          <p class="text-3xl font-bold <%= @account.balance.positive? ? 'text-red-600' : 'text-green-700' %>">
            <%= number_to_currency(@account.balance, unit: "$", separator: ",", delimiter: ".") %>
          </p>
          <p class="text-xs text-gray-500 mt-1">Deuda actual COP</p>
          <div class="mt-2 text-right space-y-0.5">
            <p class="text-sm text-gray-600">
              Cupo disponible:
              <span class="font-semibold text-gray-800">
                <%= number_to_currency(@account.available_credit, unit: "$", separator: ",", delimiter: ".") %> COP
              </span>
            </p>
            <p class="text-sm text-gray-500">
              Cupo total:
              <span class="font-semibold"><%= number_to_currency(@account.credit_limit, unit: "$", separator: ",", delimiter: ".") %> COP</span>
            </p>
          </div>
        <% else %>
          <p class="text-3xl font-bold <%= @account.balance.negative? ? 'text-red-600' : 'text-green-700' %>">
            <%= number_to_currency(@account.balance, unit: "$", separator: ",", delimiter: ".") %>
          </p>
          <p class="text-xs text-gray-500 mt-1">Saldo actual COP</p>
        <% end %>
      </div>
    </div>
    <div class="flex gap-3 mt-4 flex-wrap">
      <%= link_to "Editar cuenta", edit_account_path(@account),
                  class: "text-sm bg-gray-100 hover:bg-gray-200 text-gray-700 px-3 py-1.5 rounded" %>
      <%= button_to "Eliminar cuenta", account_path(@account), method: :delete,
                    class: "text-sm bg-red-100 hover:bg-red-200 text-red-700 px-3 py-1.5 rounded",
                    form: { onsubmit: "return confirm('¿Eliminar esta cuenta y todas sus transacciones?')" } %>
      <%= link_to export_xlsx_account_path(@account, format: :xlsx),
                  class: "text-sm bg-green-100 hover:bg-green-200 text-green-700 px-3 py-1.5 rounded" do %>
        Exportar movimientos
      <% end %>
      <%= link_to "Volver", accounts_path,
                  class: "text-sm text-gray-500 hover:underline px-3 py-1.5" %>
    </div>
  </div>

  <!-- Formulario de nueva transacción -->
  <div class="bg-white rounded-xl shadow p-6 border border-gray-100">
    <h2 class="text-lg font-semibold text-gray-800 mb-4">Registrar Transacción</h2>
    <%= form_with model: [@account, @new_transaction], local: true, class: "space-y-4" do |f| %>
      <% if @new_transaction.errors.any? %>
        <div class="bg-red-50 border border-red-200 rounded p-3 text-sm text-red-700">
          <ul class="list-disc pl-4 space-y-1">
            <% @new_transaction.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <%= f.label :transaction_type, "Tipo", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <% if @account.credit? %>
            <%= f.select :transaction_type,
                         [["Compra (aumenta deuda)", "expense"], ["Pago (reduce deuda)", "income"]],
                         {},
                         class: "w-full border border-gray-300 rounded px-3 py-2" %>
          <% else %>
            <%= f.select :transaction_type,
                         Transaction.transaction_types.map { |k, _| [t("enums.transaction.transaction_type.#{k}"), k] },
                         {},
                         class: "w-full border border-gray-300 rounded px-3 py-2" %>
          <% end %>
        </div>
        <div>
          <%= f.label :amount, "Valor (COP)", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <input type="text"
                 id="amount_display"
                 placeholder="0"
                 inputmode="numeric"
                 autocomplete="off"
                 class="w-full border border-gray-300 rounded px-3 py-2 focus:ring focus:ring-blue-200">
          <%= f.hidden_field :amount, id: "amount_raw" %>
        </div>
        <div>
          <%= f.label :transaction_date, "Fecha", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.date_field :transaction_date, value: Date.current,
                           class: "w-full border border-gray-300 rounded px-3 py-2" %>
        </div>
        <div>
          <%= f.label :description, "Descripción", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :description, placeholder: "Describe la transacción",
                           class: "w-full border border-gray-300 rounded px-3 py-2" %>
        </div>
      </div>
      <div class="flex justify-end">
        <%= f.submit "Registrar",
                     class: "bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded text-sm font-medium" %>
      </div>
    <% end %>
  </div>

  <script>
    (function () {
      const display = document.getElementById('amount_display');
      const raw     = document.getElementById('amount_raw');
      display.addEventListener('input', function () {
        const digits = this.value.replace(/\D/g, '');
        this.value   = digits.replace(/\B(?=(\d{3})+(?!\d))/g, '.');
        raw.value    = digits;
      });
    })();
  </script>

  <!-- Listado de transacciones -->
  <div class="bg-white rounded-xl shadow border border-gray-100 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100">
      <h2 class="text-lg font-semibold text-gray-800">
        Movimientos
        <span class="text-sm font-normal text-gray-500">(<%= @transactions.count %>)</span>
      </h2>
    </div>

    <% if @transactions.any? %>
      <!-- Tabla (escritorio) -->
      <div class="hidden sm:block overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 text-gray-600 uppercase text-xs">
            <tr>
              <th class="px-4 py-3 text-left">Fecha</th>
              <th class="px-4 py-3 text-left">Descripción</th>
              <th class="px-4 py-3 text-left">Tipo</th>
              <th class="px-4 py-3 text-right">Valor</th>
              <th class="px-4 py-3 text-center">Acción</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @transactions.each do |tx| %>
              <tr class="hover:bg-gray-50">
                <td class="px-4 py-3 text-gray-500 whitespace-nowrap">
                  <%= tx.transaction_date&.strftime("%d/%m/%Y") || "-" %>
                </td>
                <td class="px-4 py-3 text-gray-800"><%= tx.description %></td>
                <td class="px-4 py-3">
                  <% if @account.credit? %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                      <%= tx.income? ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
                      <%= tx.income? ? "Pago" : "Compra" %>
                    </span>
                  <% else %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                      <%= tx.income? ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
                      <%= t("enums.transaction.transaction_type.#{tx.transaction_type}") %>
                    </span>
                  <% end %>
                </td>
                <td class="px-4 py-3 text-right font-semibold <%= @account.credit? ? (tx.income? ? 'text-green-700' : 'text-red-600') : (tx.income? ? 'text-green-700' : 'text-red-600') %>">
                  <% if @account.credit? %>
                    <%= tx.income? ? "-" : "+" %>
                  <% else %>
                    <%= tx.income? ? "+" : "-" %>
                  <% end %>
                  <%= number_to_currency(tx.amount, unit: "$", separator: ",", delimiter: ".") %>
                </td>
                <td class="px-4 py-3 text-center">
                  <div class="flex justify-center items-center gap-3">
                    <% if tx.expense_id.present? %>
                      <%= link_to "Ver gasto", edit_expense_path(tx.expense),
                                  class: "text-xs text-blue-600 hover:underline" %>
                      <span class="text-xs text-gray-400">Vinculado a gasto</span>
                    <% else %>
                      <%= button_to "Eliminar",
                                    account_transaction_path(@account, tx),
                                    method: :delete,
                                    class: "text-xs text-red-600 hover:underline bg-transparent border-0 cursor-pointer",
                                    form: { onsubmit: "return confirm('¿Eliminar esta transacción? El saldo se ajustará automáticamente.')" } %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <!-- Tarjetas (móvil) -->
      <div class="sm:hidden divide-y divide-gray-100">
        <% @transactions.each do |tx| %>
          <div class="px-4 py-4 hover:bg-gray-50 transition-colors">
            <!-- Franja de color izquierda + contenido -->
            <div class="flex items-stretch gap-3">
              <!-- Indicador visual de tipo -->
              <div class="w-1 rounded-full flex-shrink-0 <%= tx.income? ? 'bg-green-400' : 'bg-red-400' %>"></div>

              <div class="flex-1 min-w-0">
                <!-- Fila 1: descripción + monto -->
                <div class="flex justify-between items-start gap-2">
                  <p class="text-sm font-semibold text-gray-800 leading-snug">
                    <%= tx.description.presence || "Sin descripción" %>
                  </p>
                  <p class="text-base font-bold flex-shrink-0 <%= (@account.credit? ? !tx.income? : !tx.income?) ? 'text-red-600' : 'text-green-700' %>">
                    <%= @account.credit? ? (tx.income? ? "−" : "+") : (tx.income? ? "+" : "−") %>
                    <%= number_to_currency(tx.amount, unit: "$", separator: ",", delimiter: ".") %>
                  </p>
                </div>

                <!-- Fila 2: fecha + badge de tipo -->
                <div class="flex items-center gap-2 mt-1.5">
                  <svg class="w-3.5 h-3.5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                  </svg>
                  <span class="text-xs text-gray-500"><%= tx.transaction_date&.strftime("%d/%m/%Y") || "-" %></span>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                    <%= tx.income? ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
                    <% if @account.credit? %>
                      <%= tx.income? ? "Pago" : "Compra" %>
                    <% else %>
                      <%= t("enums.transaction.transaction_type.#{tx.transaction_type}") %>
                    <% end %>
                  </span>
                </div>

                <!-- Fila 3: acciones -->
                <div class="flex items-center gap-3 mt-2.5">
                  <% if tx.expense_id.present? %>
                    <%= link_to edit_expense_path(tx.expense),
                                class: "inline-flex items-center gap-1 text-xs text-blue-600 bg-blue-50 hover:bg-blue-100 px-2.5 py-1 rounded-full transition-colors" do %>
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                      </svg>
                      Ver gasto
                    <% end %>
                    <span class="inline-flex items-center text-xs text-gray-400 bg-gray-100 px-2.5 py-1 rounded-full">Vinculado a gasto</span>
                  <% else %>
                    <%= button_to account_transaction_path(@account, tx),
                                  method: :delete,
                                  class: "inline-flex items-center gap-1 text-xs text-red-600 bg-red-50 hover:bg-red-100 px-2.5 py-1 rounded-full transition-colors border-0 cursor-pointer",
                                  form: { onsubmit: "return confirm('¿Eliminar esta transacción? El saldo se ajustará automáticamente.')" } do %>
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                      </svg>
                      Eliminar
                    <% end %>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-center text-gray-500 py-10 text-sm">No hay movimientos registrados.</p>
    <% end %>
  </div>
</div>
