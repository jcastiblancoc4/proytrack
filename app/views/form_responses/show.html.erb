<div class="max-w-3xl mx-auto mt-6 px-4 pb-10">

  <!-- Breadcrumb -->
  <div class="flex items-center gap-1 mb-4 text-sm text-gray-400">
    <%= link_to inspection_forms_path, class: "hover:text-gray-600" do %>Inspecciones<% end %>
    <span>/</span>
    <%= link_to inspection_form_path(@inspection_form), class: "hover:text-gray-600" do %><%= @inspection_form.code %><% end %>
    <span>/</span>
    <span class="text-gray-600 font-medium">Respuesta</span>
  </div>

  <!-- Header -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 mb-6">
    <div class="flex items-start justify-between flex-wrap gap-4">
      <div>
        <h1 class="text-xl font-bold text-gray-800 mb-1">Registro de Inspección</h1>
        <p class="text-sm text-gray-500"><%= @inspection_form.name %></p>
      </div>
      <%= button_to inspection_form_form_response_path(@inspection_form, @form_response),
            method: :delete,
            form: { data: { turbo_confirm: "¿Eliminar este registro de inspección?" } },
            class: "inline-flex items-center gap-1.5 px-3 py-2 text-sm font-medium text-red-700 bg-red-50 border border-red-200 rounded-lg hover:bg-red-100 transition-colors self-start" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
        Eliminar
      <% end %>
    </div>

    <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="bg-gray-50 rounded-lg p-3">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Responsable</p>
        <p class="text-sm font-semibold text-gray-800"><%= @form_response.responsible.full_name %></p>
        <p class="text-xs text-gray-500">
          <%= @form_response.responsible.document_type_label %> <%= @form_response.responsible.document_number %>
        </p>
      </div>
      <div class="bg-gray-50 rounded-lg p-3">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Fecha y hora de inspección</p>
        <p class="text-sm font-semibold text-gray-800">
          <%= @form_response.inspection_datetime.strftime("%d/%m/%Y") %>
        </p>
        <p class="text-xs text-gray-500">
          <%= @form_response.inspection_datetime.strftime("%H:%M") %> hrs
        </p>
      </div>
    </div>
  </div>

  <!-- Respuestas -->
  <h2 class="text-base font-semibold text-gray-700 mb-3">
    Respuestas (<%= @form_response.responses.count %>)
  </h2>

  <% responses_by_question = @form_response.responses.index_by(&:question_id) %>

  <div class="space-y-4">
    <% @inspection_form.questions.each_with_index do |q, i| %>
      <% resp = responses_by_question[q.id] %>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5">
        <div class="flex items-start gap-3 mb-3">
          <span class="flex-shrink-0 w-7 h-7 rounded-full bg-green-700 text-white text-xs font-bold flex items-center justify-center mt-0.5">
            <%= i + 1 %>
          </span>
          <div class="flex-1">
            <p class="font-medium text-gray-800 mb-2"><%= q.question %></p>

            <% if resp.nil? %>
              <p class="text-sm text-gray-400 italic">Sin respuesta</p>

            <% elsif q.written_response? %>
              <div class="bg-gray-50 border border-gray-200 rounded-lg px-4 py-3">
                <p class="text-sm text-gray-800"><%= resp.string_answer.presence || "—" %></p>
              </div>

            <% elsif q.options? %>
              <div class="space-y-1">
                <% q.options.each do |opt| %>
                  <div class="flex items-center gap-2">
                    <% selected = resp.string_answer == opt %>
                    <span class="w-4 h-4 rounded-full border-2 flex items-center justify-center flex-shrink-0
                                 <%= selected ? 'border-green-600 bg-green-600' : 'border-gray-300' %>">
                      <% if selected %>
                        <span class="w-2 h-2 rounded-full bg-white"></span>
                      <% end %>
                    </span>
                    <span class="text-sm <%= selected ? 'text-green-700 font-medium' : 'text-gray-500' %>">
                      <%= opt %>
                    </span>
                  </div>
                <% end %>
              </div>

            <% elsif q.boxes? %>
              <div class="space-y-1">
                <% q.boxes.each do |box| %>
                  <% checked = resp.array_answer.include?(box) %>
                  <div class="flex items-center gap-2">
                    <span class="w-4 h-4 rounded border-2 flex items-center justify-center flex-shrink-0
                                 <%= checked ? 'border-green-600 bg-green-600' : 'border-gray-300' %>">
                      <% if checked %>
                        <svg class="w-2.5 h-2.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                        </svg>
                      <% end %>
                    </span>
                    <span class="text-sm <%= checked ? 'text-green-700 font-medium' : 'text-gray-500' %>">
                      <%= box %>
                    </span>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="mt-6">
    <%= link_to inspection_form_path(@inspection_form),
          class: "text-sm text-gray-500 hover:text-gray-700 flex items-center gap-1" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Volver al formulario
    <% end %>
  </div>
</div>
