<div class="max-w-3xl mx-auto mt-6 px-4 pb-10">

  <!-- Breadcrumb -->
  <div class="flex items-center gap-1 mb-4 text-sm text-gray-400">
    <%= link_to inspection_forms_path, class: "hover:text-gray-600" do %>Inspecciones<% end %>
    <span>/</span>
    <%= link_to inspection_form_path(@inspection_form), class: "hover:text-gray-600" do %><%= @inspection_form.code %><% end %>
    <span>/</span>
    <span class="text-gray-600 font-medium">Respuesta</span>
  </div>

  <!-- Header -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 mb-6">
    <div class="flex items-start justify-between">
      <div>
        <h1 class="text-xl font-bold text-gray-800 mb-1">Registro de Inspección</h1>
        <p class="text-sm text-gray-500"><%= @inspection_form.name %></p>
      </div>
      <% if @form_response.pdf_report.present? %>
        <%= link_to download_pdf_inspection_form_form_response_path(@inspection_form, @form_response), target: "_blank",
              class: "inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white bg-red-600 hover:bg-red-700 rounded-lg transition-colors" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
          </svg>
          Descargar PDF
        <% end %>
      <% end %>
    </div>

    <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="bg-gray-50 rounded-lg p-3">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Respondido por</p>
        <p class="text-sm font-semibold text-gray-800"><%= @form_response.respondent_name %></p>
        <% if @form_response.user&.profile %>
          <p class="text-xs text-gray-500"><%= @form_response.user.profile.position.to_s.capitalize %></p>
        <% end %>
      </div>
      <div class="bg-gray-50 rounded-lg p-3">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Versión del formulario</p>
        <div class="flex items-center gap-2 mt-1">
          <span class="text-sm font-semibold text-gray-800">v<%= @form_response.form_version %></span>
          <% if @form_response.current_version? %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">Versión actual</span>
          <% else %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-700">Versión anterior</span>
          <% end %>
        </div>
      </div>
      <div class="bg-gray-50 rounded-lg p-3">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Fecha y hora de inspección</p>
        <p class="text-sm font-semibold text-gray-800">
          <%= @form_response.inspection_datetime.strftime("%d/%m/%Y") %>
        </p>
        <p class="text-xs text-gray-500">
          <%= @form_response.inspection_datetime.strftime("%H:%M") %> hrs
        </p>
      </div>
    </div>
  </div>

  <!-- Respuestas -->
  <h2 class="text-base font-semibold text-gray-700 mb-3">
    Respuestas (<%= @form_response.responses.count %>)
  </h2>

  <div class="space-y-4">
    <% @form_response.responses.each_with_index do |resp, i| %>
      <% question = resp.question %>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5">
        <div class="flex items-start gap-3 mb-3">
          <span class="flex-shrink-0 w-7 h-7 rounded-full bg-green-700 text-white text-xs font-bold flex items-center justify-center mt-0.5">
            <%= i + 1 %>
          </span>
          <div class="flex-1">
            <p class="font-medium text-gray-800 mb-2"><%= resp.question_text.presence || question&.question || "Pregunta eliminada" %></p>

            <% if resp.string_answer.present? %>
              <% if question&.options? %>
                <div class="space-y-1">
                  <% (question.options).each do |opt| %>
                    <div class="flex items-center gap-2">
                      <% selected = resp.string_answer == opt %>
                      <span class="w-4 h-4 rounded-full border-2 flex items-center justify-center flex-shrink-0
                                   <%= selected ? 'border-green-600 bg-green-600' : 'border-gray-300' %>">
                        <% if selected %><span class="w-2 h-2 rounded-full bg-white"></span><% end %>
                      </span>
                      <span class="text-sm <%= selected ? 'text-green-700 font-medium' : 'text-gray-500' %>"><%= opt %></span>
                    </div>
                  <% end %>
                </div>
              <% else %>
                <div class="bg-gray-50 border border-gray-200 rounded-lg px-4 py-3">
                  <p class="text-sm text-gray-800"><%= resp.string_answer %></p>
                </div>
              <% end %>

            <% elsif resp.array_answer.any? %>
              <div class="space-y-1">
                <% (question&.boxes || resp.array_answer).each do |box| %>
                  <% checked = resp.array_answer.include?(box) %>
                  <div class="flex items-center gap-2">
                    <span class="w-4 h-4 rounded border-2 flex items-center justify-center flex-shrink-0
                                 <%= checked ? 'border-green-600 bg-green-600' : 'border-gray-300' %>">
                      <% if checked %>
                        <svg class="w-2.5 h-2.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                        </svg>
                      <% end %>
                    </span>
                    <span class="text-sm <%= checked ? 'text-green-700 font-medium' : 'text-gray-500' %>"><%= box %></span>
                  </div>
                <% end %>
              </div>

            <% else %>
              <p class="text-sm text-gray-400 italic">Sin respuesta</p>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="mt-6">
    <%= link_to inspection_form_path(@inspection_form),
          class: "text-sm text-gray-500 hover:text-gray-700 flex items-center gap-1" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Volver al formulario
    <% end %>
  </div>
</div>
