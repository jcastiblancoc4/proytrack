<div class="max-w-3xl mx-auto mt-6 px-4 pb-10">

  <!-- Header -->
  <div class="mb-6">
    <div class="flex items-center gap-2 mb-1 flex-wrap">
      <%= link_to inspection_forms_path,
            class: "text-sm text-gray-400 hover:text-gray-600 flex items-center gap-1" do %>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        <%= @inspection_form.code %>
      <% end %>
    </div>
    <h1 class="text-2xl font-bold text-gray-800">Responder Formulario</h1>
    <p class="text-sm text-gray-500 mt-1"><%= @inspection_form.name %></p>
  </div>

  <% if @form_response.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
      <h3 class="text-sm font-medium text-red-800 mb-2">Se encontraron errores:</h3>
      <ul class="list-disc pl-5 space-y-1 text-sm text-red-700">
        <% @form_response.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with url: inspection_form_form_responses_path(@inspection_form), method: :post, local: true do |f| %>

    <!-- Preguntas -->
    <% if @inspection_form.current_questions.empty? %>
      <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-6 mb-6 text-center">
        <p class="text-sm text-yellow-800">Este formulario no tiene preguntas. Comunícate con tu administrador.</p>
      </div>
    <% else %>
      <div class="space-y-4 mb-6">
        <h2 class="text-base font-semibold text-gray-700">Preguntas (<%= @inspection_form.current_questions.count %>)</h2>

        <% @inspection_form.current_questions.each_with_index do |q, i| %>
          <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5">
            <div class="flex items-start gap-3 mb-4">
              <span class="flex-shrink-0 w-7 h-7 rounded-full bg-green-700 text-white text-xs font-bold flex items-center justify-center mt-0.5">
                <%= i + 1 %>
              </span>
              <p class="font-medium text-gray-800"><%= q.question %></p>
            </div>

            <% if q.written_response? %>
              <% if q.written_response.present? %>
                <p class="text-xs text-gray-500 mb-2 ml-10"><%= q.written_response %></p>
              <% end %>
              <textarea name="responses[<%= q.id %>][string_answer]"
                        rows="3"
                        placeholder="Escribe tu respuesta aquí..."
                        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-green-300 focus:border-green-500 outline-none resize-none"></textarea>

            <% elsif q.options? %>
              <div class="space-y-2 ml-10">
                <% q.options.each do |opt| %>
                  <label class="flex items-center gap-3 cursor-pointer group">
                    <input type="radio"
                           name="responses[<%= q.id %>][string_answer]"
                           value="<%= opt %>"
                           class="w-4 h-4 text-green-700 border-gray-300 focus:ring-green-500">
                    <span class="text-sm text-gray-700 group-hover:text-gray-900"><%= opt %></span>
                  </label>
                <% end %>
              </div>

            <% elsif q.boxes? %>
              <div class="space-y-2 ml-10">
                <% q.boxes.each do |box| %>
                  <label class="flex items-center gap-3 cursor-pointer group">
                    <input type="checkbox"
                           name="responses[<%= q.id %>][array_answer][]"
                           value="<%= box %>"
                           class="w-4 h-4 rounded text-green-700 border-gray-300 focus:ring-green-500">
                    <span class="text-sm text-gray-700 group-hover:text-gray-900"><%= box %></span>
                  </label>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <!-- Firma -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5 mb-6">
      <h2 class="text-base font-semibold text-gray-700 mb-1">Firma del responsable</h2>
      <p class="text-xs text-gray-500 mb-3">Dibuja tu firma en el recuadro de abajo.</p>
      <div class="border border-gray-300 rounded-lg overflow-hidden bg-white" style="touch-action: none;">
        <canvas id="signature-canvas" class="w-full block" style="height: 160px; cursor: crosshair;"></canvas>
      </div>
      <div class="flex justify-end mt-2">
        <button type="button" id="clear-signature"
                class="text-xs text-gray-400 hover:text-red-500 underline transition-colors">
          Limpiar firma
        </button>
      </div>
      <input type="hidden" name="signature_data" id="signature-data">
    </div>

    <!-- Acciones -->
    <div class="flex items-center justify-between">
      <%= link_to inspection_forms_path,
            class: "text-sm text-gray-500 hover:text-gray-700" do %>Cancelar<% end %>
      <button type="submit"
              class="inline-flex items-center gap-2 bg-green-700 hover:bg-green-800 text-white font-medium px-6 py-2.5 rounded-lg transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
        Guardar inspección
      </button>
    </div>
  <% end %>

  <script>
    (function () {
      const canvas = document.getElementById('signature-canvas');
      const input  = document.getElementById('signature-data');
      const ctx    = canvas.getContext('2d');
      let drawing  = false;
      let hasDrawn = false;

      function resize() {
        const ratio  = window.devicePixelRatio || 1;
        const rect   = canvas.getBoundingClientRect();
        canvas.width  = rect.width  * ratio;
        canvas.height = rect.height * ratio;
        ctx.scale(ratio, ratio);
        ctx.strokeStyle = '#1a1a1a';
        ctx.lineWidth   = 2;
        ctx.lineCap     = 'round';
        ctx.lineJoin    = 'round';
      }

      function getPos(e) {
        const rect = canvas.getBoundingClientRect();
        const src  = e.touches ? e.touches[0] : e;
        return { x: src.clientX - rect.left, y: src.clientY - rect.top };
      }

      function onStart(e) {
        e.preventDefault();
        drawing = true;
        const p = getPos(e);
        ctx.beginPath();
        ctx.moveTo(p.x, p.y);
      }

      function onMove(e) {
        e.preventDefault();
        if (!drawing) return;
        hasDrawn = true;
        const p = getPos(e);
        ctx.lineTo(p.x, p.y);
        ctx.stroke();
      }

      function onStop(e) {
        e.preventDefault();
        drawing = false;
        if (hasDrawn) input.value = canvas.toDataURL('image/png');
      }

      canvas.addEventListener('mousedown',  onStart);
      canvas.addEventListener('mousemove',  onMove);
      canvas.addEventListener('mouseup',    onStop);
      canvas.addEventListener('mouseleave', onStop);
      canvas.addEventListener('touchstart', onStart, { passive: false });
      canvas.addEventListener('touchmove',  onMove,  { passive: false });
      canvas.addEventListener('touchend',   onStop);

      document.getElementById('clear-signature').addEventListener('click', function () {
        const rect = canvas.getBoundingClientRect();
        ctx.clearRect(0, 0, rect.width, rect.height);
        input.value = '';
        hasDrawn = false;
      });

      resize();
      window.addEventListener('resize', function () { resize(); });
    })();
  </script>
</div>
